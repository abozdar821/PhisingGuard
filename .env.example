# ── Anthropic (Claude AI) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AWS Credentials ──────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# ── AWS DynamoDB Table Names ─────────────────────────
DYNAMODB_SCANS_TABLE=phishguard-scans
DYNAMODB_PATTERNS_TABLE=phishguard-patterns
DYNAMODB_TRAINING_TABLE=phishguard-training

# ── Google Safe Browsing API ─────────────────────────
GOOGLE_SAFE_BROWSING_KEY=AIza...

# ── Google OAuth (Gmail import) ──────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# ── Microsoft OAuth (Outlook import) ────────────────
NEXT_PUBLIC_MSAL_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── App Config ───────────────────────────────────────
# Set to 'public' for open access, or use your own auth
NEXT_PUBLIC_APP_MODE=public
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# ── Admin API ─────────────────────────────────────────
# Required to POST to /api/patterns (add/update threat intelligence)
# Pass as header: x-admin-key: <value>
ADMIN_API_KEY=change-me-to-a-strong-random-secret
